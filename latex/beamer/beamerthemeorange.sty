\defbeamertemplate*{footline}{orangebody}
{
  \leavevmode%
  \hskip.03\paperwidth
  %\includegraphics[width=.09\paperwidth]{logo_FT}
  \begin{beamercolorbox}[wd=.07\paperwidth,ht=2.5ex,dp=1.125ex]{dateorange in head/foot}%
   \textbf{\usebeamerfont{dateorange in head/foot}\insertframenumber{} / \inserttotalframenumber{}}\hspace*{2ex}\ 
  \end{beamercolorbox}
  \hbox{\begin{beamercolorbox}[wd=.6\paperwidth,ht=2.5ex,dp=1.125ex]{authororange in head/foot}%
   \usebeamerfont{authororange in head/foot}\textbf{Orange Labs -- \insertshortauthor: \insertshorttitle\ -- \insertshortdate}
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.3\paperwidth,ht=2.5ex,dp=1.125ex]{titleorange in head/foot}%
   \hfill\usebeamerfont{titleorange in head/foot}\textbf{France T\'el\'ecom Group Unrestricted}\hfill\
  \end{beamercolorbox}
}%
  %\includegraphics[width=.09\paperwidth]{logo_orange} 
  %\hskip.01\paperwidth
  \vskip0pt%
%  \ \parbox{.33\paperwidth}{\insertshortauthor}\parbox{.33\paperwidth}{\hfill\insertshorttitle\hfill\ }\parbox{.33\paperwidth}{\hfill\insertframenumber{} / \inserttotalframenumber\hspace*{2ex}}
 % \hfill\pgfuseimage{orange-logo-bottom}\hfill\ 
 % \insertshortdate{}
}

\defbeamertemplate*{navigation symbols}{orange}
{%
   {%
     \hbox{\insertslidenavigationsymbol}
