   }%
}




\defbeamertemplate{footline}{orangetitle}
{
  \leavevmode%
  \hskip.01\paperwidth
  \includegraphics[width=.09\paperwidth]{logo_FT}
  \hskip.3\paperwidth
  \hbox{\begin{beamercolorbox}[wd=.5\paperwidth,ht=2.5ex,dp=1.125ex]{no authororange in foot on title page} \textbf{France T\'el\'ecom Group Unrestricted} %
  \end{beamercolorbox}}%
  \includegraphics[width=.09\paperwidth]{logo_orange} 
  \hskip.01\paperwidth
  \vskip0pt%
}



\setbeamertemplate{footline}[orangetitle]
