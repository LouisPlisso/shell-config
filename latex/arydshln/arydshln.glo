\glossaryentry{v1.4-3-3>x10072adl@org@tabclassz=\verb!*+\adl@org@tabclassz+:>Introduced to restore \hbox {\tt  \char \escapechar @tabclassz}.}{17}
\glossaryentry{v1.4-3-3>x10073adl@org@classz=\verb!*+\adl@org@classz+:>Introduced to restore \hbox {\tt  \char \escapechar @classz}.}{17}
\glossaryentry{v1.4-3-3>x10074adl@org@@startpbox=\verb!*+\adl@org@@startpbox+:>Introduced to restore \hbox {\tt  \char \escapechar @@startpbox}.}{17}
\glossaryentry{v1.4-3-3>x10075adl@org@@endpbox=\verb!*+\adl@org@@endpbox+:>Introduced to restore \hbox {\tt  \char \escapechar @@endpbox}.}{17}
\glossaryentry{v1.4-3-3>x10076adl@org@endpbox=\verb!*+\adl@org@endpbox+:>Introduced to restore \hbox {\tt  \char \escapechar @endpbox}.}{17}
\glossaryentry{v1.4-3-3>x10077adl@org@cline=\verb!*+\adl@org@cline+:>Introduced to restore \hbox {\tt  \char \escapechar cline}.}{17}
\glossaryentry{v1.4-3-6>x10078adl@org@cline=\verb!*+\adl@org@cline+:>Introduced to refer original version in modified \hbox {\tt  \char \escapechar cline}.}{17}
\glossaryentry{v1.4-3-1>x10079adl@array=\verb!*+\adl@array+:>Introduced to save original definition of \hbox {\tt  \char \escapechar @array}.}{17}
\glossaryentry{v1.4-3-1>x10080@array=\verb!*+\@array+:>Drastically modified to avoid copy-and-modify.}{17}
\glossaryentry{v1.7-2>x10081adl@noalign=\verb!*+\adl@noalign+:>Introduced to fix a bug of \textsf  {colortbl}.}{17}
