\glossaryentry{v1.6-1>x10089adl@discard=\verb!*+\adl@discard+:>Add initializetion of \hbox {\tt  \char \escapechar adl@discard}.}{19}
\glossaryentry{v1.4-3-1>x10090adl@arrayinit=\verb!*+\adl@arrayinit+:>Modified for new column counting in preamble construction.}{19}
\glossaryentry{v1.4-3-3>x10091adl@arrayinit=\verb!*+\adl@arrayinit+:>Modified to call \hbox {\tt  \char \escapechar adl@inactivate}.}{19}
\glossaryentry{v1.5-3>x10092adl@arrayinit=\verb!*+\adl@arrayinit+:>Move \hbox {\tt  \char \escapechar adl@inactivate} from \hbox {\tt  \char \escapechar adl@arrayinit} to \hbox {\tt  \char \escapechar @array}.}{19}
\glossaryentry{v1.4-3-3>x10093adl@inactivate=\verb!*+\adl@inactivate+:>Introduced to inactivate \hbox {\tt  \char \escapechar @arrayclassz} etc.}{19}
\glossaryentry{v1.5-3>x10094adl@inactivate=\verb!*+\adl@inactivate+:>Change \hbox {\tt  \char \escapechar adl@inactivate} caller to \hbox {\tt  \char \escapechar @array}.}{19}
