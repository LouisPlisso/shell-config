\mode<presentation>

\definecolor{grisft}{rgb}{.259,.290,.325}
\definecolor{orft}{rgb}{1.0,.4,0}
\definecolor{comp1}{rgb}{0.0,0.0,0.0}
\definecolor{comp2}{rgb}{0.2,0.169,.141}
\definecolor{comp4}{rgb}{.812,.769,.722}
\definecolor{white2}{rgb}{1.0,1.0,1.0}

\setbeamercolor{normal text}{fg=black,bg=white}
\setbeamercolor{alerted text}{fg=orft,bg=comp4}
\setbeamercolor{example text}{fg=grisft}
\setbeamercolor{structure}{fg=orft,bg=white}
\setbeamercolor{background canvas}{parent=normal text}

% Headline and footline
%\defbeamertemplate*{headline}{orange}
%{
%  \includegraphics[width=.09\paperwidth]{logo_FT} \hfill\includegraphics[width=.09\paperwidth]{logo_orange}\ 
%}

\defbeamertemplate*{footline}{orange}
{
  \leavevmode%
  \hskip.01\paperwidth
  \includegraphics[width=.09\paperwidth]{logo_FT}
  \hbox{\begin{beamercolorbox}[wd=.2\paperwidth,ht=2.5ex,dp=1.125ex]{authororange in head/foot}%
    \usebeamerfont{authororange in head/foot}\hspace{1em}\insertshortauthor
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.4\paperwidth,ht=2.5ex,dp=1.125ex]{titleorange in head/foot}%
    \hfill\usebeamerfont{titleorange in head/foot}\insertshorttitle\hfill\
  \end{beamercolorbox}
  \begin{beamercolorbox}[wd=.2\paperwidth,ht=2.5ex,dp=1.125ex]{dateorange in head/foot}%
    \hfill\usebeamerfont{dateorange in head/foot}\insertframenumber{} / \inserttotalframenumber{}\hspace*{2ex}\ 
  \end{beamercolorbox}}%
  \includegraphics[width=.09\paperwidth]{logo_orange} 
  \hskip.01\paperwidth
  \vskip0pt%
%  \ \parbox{.33\paperwidth}{\insertshortauthor}\parbox{.33\paperwidth}{\hfill\insertshorttitle\hfill\ }\parbox{.33\paperwidth}{\hfill\insertframenumber{} / \inserttotalframenumber\hspace*{2ex}}
 % \hfill\pgfuseimage{orange-logo-bottom}\hfill\ 
 % \insertshortdate{}
}




