#include "/usr/share/X11/locale/en_US.UTF-8/Compose"

<Multi_key>    <x>  <y> :   "\"*y"   # vi x buffer yank
<Multi_key>    <x>  <d> :   "\"*d"   # vi x buffer delete
<Multi_key>    <x>  <p> :   "\"*p"   # vi x buffer paste
<Multi_key>    <x>  <c> :   "\"*c"   # vi x buffer change
<Multi_key>    <x>  <Y> :   "\"*y$"   # vi x buffer yank
<Multi_key>    <x>  <D> :   "\"*D"   # vi x buffer delete
<Multi_key>    <x>  <P> :   "\"*P"   # vi x buffer paste
<Multi_key>    <x>  <C> :   "\"*C"   # vi x buffer change


<Multi_key>    <^>  <a> :   "â"     # terminal a circum
<Multi_key>    <^>  <e> :   "ê"     # terminal e circum
<Multi_key>    <^>  <i> :   "î"     # terminal i circum
<Multi_key>    <^>  <o> :   "ô"     # terminal o circum
<Multi_key>    <^>  <û> :   "î"     # terminal u circum


