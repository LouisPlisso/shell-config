! keycode 92 = Alt_L

! Swap caps lock and escape
remove Lock = Caps_Lock
keysym Escape = Caps_Lock
keysym Caps_Lock = Escape
add Lock = Caps_Lock

! Right act like the Left to avoid digital gymnastics.
keycode 64 = Alt_L
keycode 108 = Meta_L

! Swap ins and delete: useful on typematrix keyboard
keycode 118 = Delete
keycode 119 = Insert
