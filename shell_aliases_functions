#!/bin/sh
# Shared aliases and functions — sourced by both zsh and bash.
# No shell-specific syntax (no zsh setopt/bindkey/autoload).

# --- Utilities ---

die() {
    result=$1; shift
    echo ": $*" >&2
    exit "$result"
}

# mkdir + cd in one step
mcd() { mkdir -p "$@" && cd "$@"; }

# Fall back to a web search if man page not found
superman() {
    /usr/bin/man "$@" || w3m -dump "http://google.com/search?q=$*&btnI" | less
}

# Jump to man page section for a specific option: manswitch tar z
manswitch() { man "$1" | less -p "^ +$2"; }

# --- Environment ---

export HISTFILE=~/.histfile
export HISTSIZE=30000
unset MAILCHECK
export PAGER=less
export EDITOR=vi
export LESS="-F -X -R $LESS"

# LaTeX: look for style/bib files in config dir
export TEXINPUTS="$MY_CONFIG_DIR/latex/:"
export BIBINPUTS="$MY_CONFIG_DIR/latex/:"

export PATH="${MY_CONFIG_DIR}/bin:${PATH}:/sbin:/usr/sbin:/usr/local/sbin"
export PATH="$HOME/.local/bin:$PATH"

# --- Colors and ls ---

if [[ "$OSTYPE" == "darwin"* ]]; then
    export LS_OPTIONS='-G'
else
    export LS_OPTIONS='--color=auto'
fi

alias l='/bin/ls $LS_OPTIONS'
alias ls='/bin/ls $LS_OPTIONS'
alias l1='/bin/ls $LS_OPTIONS -1'
alias ll='/bin/ls $LS_OPTIONS -l'
alias la='/bin/ls $LS_OPTIONS -Alh'
alias lsd='/bin/ls $LS_OPTIONS -d */'
alias lt='/bin/ls $LS_OPTIONS -lhart'       # sorted by time, newest last

# --- grep ---

alias grep='grep --color=auto'
alias xg='xargs grep --color=auto'

# --- find: always exclude *~ backup files, regular files only ---
# Wraps /usr/bin/find to hide editor backup files from all searches.
# To bypass this filter, call /usr/bin/find directly.
find() {
    if [ $# -eq 0 ]; then set -- .; fi
    /usr/bin/find "$@" ! \( -name "*~" \) -type f
}
fj()  { find "${@:-.}" -name "*.java"; }
fgo() { find "${@:-.}" -name "*.go"; }
fp()  { find "${@:-.}" -name "*.py"; }
fr()  { find "${@:-.}" -name "*.rb"; }

# --- Python ---

alias pyprofile='python -m cProfile -s time'
alias pypy=pypy3
alias pyl='pylint --output-format=colorized --reports=n --disable=C0103 --disable=W0141 --disable=E1101'
alias pysh='ipython -p pysh'

# --- Misc ---

alias sqlite='sqlite3'
alias 'cd..'='cd ..'
alias cdc='cd "$MY_CONFIG_DIR"'

# --- Git ---

# Compact graph log with relative dates
alias gl='git log --graph --pretty=format:"%Cred%h%Creset — %s %Cgreen(%cr)%Creset" --abbrev-commit --date=relative'
alias gst='git status'
alias gco='git commit -a'
alias gdp="git diff 'HEAD^'"
alias gd='git diff'
alias gch='git checkout'
alias gpull='git pull && git submodule update --recursive'
