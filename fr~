partial alphanumeric_keys
xkb_symbols "oss" {

    include "latin"
    include "level3(ralt_switch)"
    include "nbsp(level4nl)"
    include "keypad(oss)"

    name[Group1]="France - Alternative";

    // First row
    key <TLDE>	{ [      twosuperior,    threesuperior,          onesuperior,          dead_cedilla ] }; // ВІ Ві В№ Вё 
    key <AE01>	{ [        ampersand,                1,           dead_caron,           dead_ogonek ] }; // & 1 ЛҮ МЁ
    key <AE02>	{ [           eacute,                2,           asciitilde,                Eacute ] }; // Г© 2 ~ Гү
    key <AE03>	{ [         quotedbl,                3,           numbersign,            dead_breve ] }; // " 3 # Лҳ
    key <AE04>	{ [       apostrophe,                4,            braceleft,             0x1002014 ] }; // ' 4 { вҖ” (tiret cadratin)
    key <AE05>	{ [        parenleft,                5,          bracketleft,             0x1002013 ] }; // ( 5 [ вҖ“ (tiret demi-cadratin)
    key <AE06>	{ [            minus,                6,                  bar,             0x1002011 ] }; // - 6 | вҖ‘ (tiret insГ©cable)
    key <AE07>	{ [           egrave,                7,                grave,                Egrave ] }; // ГЁ 7 ` ГҲ
    key <AE08>	{ [       underscore,                8,            backslash,             trademark ] }; // _ 8 \ в„ў
    key <AE09>	{ [         ccedilla,                9,          asciicircum,              Ccedilla ] }; // Г§ 9 ^ ГҮ
    key <AE10>	{ [           agrave,                0,                   at,                Agrave ] }; // Г  0 @ ГҖ
    key <AE11>	{ [       parenright,           degree,         bracketright,              notequal ] }; // ) В° ] вү  
    key <AE12>	{ [            equal,             plus,           braceright,             plusminus ] }; // = + } Вұ

    // Second row
    key <AD01>	{ [                a,                A,                   ae,                    AE ] }; // a A ГҰ ГҶ
    key <AD02>	{ [                z,                Z,          acircumflex,           Acircumflex ] }; // z Z Гў ГӮ
    key <AD03>	{ [                e,                E,             EuroSign,                  cent ] }; // e E вӮ¬ Вў
    key <AD04>	{ [                r,                R,          ecircumflex,           Ecircumflex ] }; // r R ГӘ ГҠ
    key <AD05>	{ [                t,                T,                thorn,                 THORN ] }; // t T Гҫ Гһ
    key <AD06>	{ [                y,                Y,           ydiaeresis,            Ydiaeresis ] }; // y Y Гҝ Её
    key <AD07>	{ [                u,                U,          ucircumflex,           Ucircumflex ] }; // u U Г» Гӣ
    key <AD08>	{ [                i,                I,          icircumflex,           Icircumflex ] }; // i I Г® ГҺ
    key <AD09>	{ [                o,                O,                   oe,                    OE ] }; // o O Е“ Е’
    key <AD10>	{ [                p,                P,          ocircumflex,           Ocircumflex ] }; // p P Гҙ Г”
    key <AD11>	{ [  dead_circumflex,   dead_diaeresis,           dead_tilde,        dead_abovering ] }; // ^ МҲ Мғ Лҡ
    key <AD12>	{ [           dollar,         sterling,               oslash,              Ooblique ] }; // $ ВЈ Гё Гҳ

    // Third row
    key <AC01>	{ [                q,                Q,           adiaeresis,            Adiaeresis ] }; // q Q ГӨ Г„
    key <AC02>	{ [                s,                S,               ssharp,    doublelowquotemark ] }; // s S Гҹ вҖһ 
    key <AC03>	{ [                d,                D,           ediaeresis,            Ediaeresis ] }; // d D Г« ГӢ
    key <AC04>	{ [                f,                F,  leftsinglequotemark,    singlelowquotemark ] }; // f F вҖҳ вҖҡ
    key <AC05>	{ [                g,                G, rightsinglequotemark,                   yen ] }; // g G вҖҷ ВҘ
    key <AC06>	{ [                h,                H,                  eth,                   ETH ] }; // h H Г° Гҗ
    key <AC07>	{ [                j,                J,           udiaeresis,            Udiaeresis ] }; // j J Гј Гң
    key <AC08>	{ [                k,                K,           idiaeresis,            Idiaeresis ] }; // k K ГҜ ГҸ
    key <AC09>	{ [                l,                L,            0x1000140,             0x100013F ] }; // l L ЕҖ Дҝ
    key <AC10>	{ [                m,                M,           odiaeresis,            Odiaeresis ] }; // m M Г¶ Г–
    key <AC11>	{ [           ugrave,          percent,           dead_acute,                Ugrave ] }; // Г№ % ' Гҷ
    key <BKSL>	{ [         asterisk,               mu,           dead_grave,           dead_macron ] }; // * Вө ` М„

    // Fourth row
    key <LSGT>  { [             less,          greater,        lessthanequal,      greaterthanequal ] }; // < > вүӨ вүҘ
    key <AB01>  { [                w,                W,        guillemotleft,   leftdoublequotemark ] }; // w W В« вҖң
    key <AB02>  { [                x,                X,       guillemotright,  rightdoublequotemark ] }; // x X В» вҖқ
    key <AB03>  { [                c,                C,            copyright,            registered ] }; // c C В© В®
    key <AB04>  { [                v,                V,            0x100202F,             leftarrow ] }; // v V вҚҪ вҶҗ (espace fine insГ©cable)
    key <AB05>  { [                b,                B,            downarrow,               uparrow ] }; // b B вҶ“ вҶ‘
    key <AB06>  { [                n,                N,              notsign,            rightarrow ] }; // n N В¬ вҶ’
    key <AB07>  { [            comma,         question,         questiondown,             0x1002026 ] }; // , ? Вҝ вҖҰ
    key <AB08>  { [        semicolon,           period,             multiply,             0x10022C5 ] }; // ; . Г— вӢ…
    key <AB09>  { [            colon,            slash,             division,             0x1002215 ] }; // : / Г· вҲ•
    key <AB10>  { [           exclam,          section,           exclamdown,             0x1002212 ] }; // ! В§ ВЎ вҲ’
};

partial alphanumeric_keys
xkb_symbols "oss_latin9" {

    // Restricts the fr(oss) layout to latin9 symbols

    include "fr(oss)"
    include "keypad(oss_latin9)"

    name[Group1]="France - Alternative, latin-9 only";

    // First row
    key <AE01>	{ [        ampersand,                1,           dead_caron,          dead_cedilla ] }; // & 1 ЛҮ Вё
    key <AE03>	{ [         quotedbl,                3,           numbersign,            dead_tilde ] }; // " 3 # ~
    key <AE04>	{ [       apostrophe,                4,            braceleft,            underscore ] }; // ' 4 { _
    key <AE05>	{ [        parenleft,                5,          bracketleft,                 minus ] }; // ( 5 [ -
    key <AE06>  { [            minus,                6,                  bar,                 minus ] }; // - 6 | -
    key <AE08>  { [       underscore,                8,            backslash,             backslash ] }; // _ 8 \ \
    key <AE11>	{ [       parenright,           degree,         bracketright,                 equal ] }; // ) В° ] =

    // Third row
    key <AC02>	{ [                s,                S,               ssharp,         guillemotleft ] }; // s S Гҹ В« 
    key <AC04>	{ [                f,                F,           apostrophe,            apostrophe ] }; // f F ' '
    key <AC05>	{ [                g,                G,           apostrophe,                   yen ] }; // g G ' ВҘ
    key <AC09>  { [                l,                L,       periodcentered,        periodcentered ] }; // l L В· В·
    key <BKSL>	{ [         asterisk,               mu,           dead_grave,       dead_circumflex ] }; // * Вө ` ^ 

    // Fourth row
    key <LSGT>  { [             less,          greater,                 less,               greater ] }; // < > < >
    key <AB01>  { [                w,                W,        guillemotleft,         guillemotleft ] }; // w W В« В«
    key <AB02>  { [                x,                X,       guillemotright,        guillemotright ] }; // x X В» В»
    key <AB04>  { [                v,                V,         nobreakspace,                  less ] }; // v V вҚҪ < (espace insГ©cable)
    key <AB05>  { [                b,                B,                minus,           asciicircum ] }; // b B - ^
    key <AB06>  { [                n,                N,              notsign,               greater ] }; // n N В¬ >
    key <AB07>  { [            comma,         question,         questiondown,                period ] }; // , ? Вҝ .
    key <AB08>  { [        semicolon,           period,             multiply,        periodcentered ] }; // ; . Г— В·
    key <AB09>  { [            colon,            slash,             division,                 slash ] }; // : / Г· /
    key <AB10>  { [           exclam,          section,           exclamdown,                 minus ] }; // ! В§ ВЎ -
};

