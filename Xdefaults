*visualBell: True
*pointerBlank: true

# transparency - true or false (default)
URxvt*transparent:true

# tint with any color; i.e., blue, red, tomato4, olivedrab2, etc.
#   some nice listings are at:
#     http://www.nisrv.com/modules.php?name=Hex_Colors
#     http://www.htmlgoodies.com/tutorials/colors/article.php/3478921
URxvt*tintColor:green

# shading - 0 to 99 darkens, 101 to 200 lightens.
# Don't use with tintColor; use a darker or lighter color instead.
#URxvt*shading:10

# background color (prior to tinting) (default is white)
URxvt*background: #555240

# font color (default is black)
URxvt*foreground: green

# xft fonts - anti-aliased xft font setup is nice, but can be choppy
#URxvt*font: xft:Bitstream Vera Sans Mono:pixelsize=12
URxvt*font: xft:DejaVu Sans Mono:size=9:VL Gothic:size=9:antialias=true:hinting=true
URxvt*boldFont: xft:DejaVu Sans Mono:size=9:VL Gothic:size=9:antialias=true:bold:hinting=true

# scrollbar style - rxvt (default), plain, next, or xterm
URxvt*scrollstyle:plain

# scrollback buffer lines - 65535 is max (64 is default)
URxvt*saveLines:65535

URxvt.perl-ext-common: default,tabbed,matcher
URxvt.tabbed.tabbar-fg: 2
URxvt.tabbed.tabbar-bg: 0
URxvt.tabbed.tab-fg: 11
URxvt.tabbed.tab-bg: 0

