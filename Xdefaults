!## urxvt ###
!##############
URxvt*font: xft:DejaVu Sans Mono:size=9:VL Gothic:size=9:antialias=true:hinting=true
URxvt*boldFont: xft:DejaVu Sans Mono:size=9:VL Gothic:size=9:antialias=true:bold:hinting=true

URxvt*background: #555240
URxvt*foreground: #fffff0
URxvt*color0: #0e100f
URxvt*color1: #646f5b
URxvt*color2: #9dad9c
URxvt*color3: #8b99b5

!URxvt*background: #08090A
!URxvt*foreground: #4b555e
!URxvt*color0: #08090A
!URxvt*color1: #4b5261
!URxvt*color2: #DFDFDF
!URxvt*color3: #8b99b5

URxvt*fading: 10
URxvt*tintColor: #FCFCFC
URxvt*shading: 90
URxvt*inheritPixmap: False
URxvt*cursorBlink: False
URxvt*cutchars: `'",;@&*=|?()<>[]{}

!!URxvt*scrollstyle: plain
!!URxvt*mouseWheelScrollPage: True
!!URxvt*jumpScroll: True
!!URxvt*skipScroll: True
!!URxvt*scrollBar: True
!!URxvt*scrollTtyOutput: True
!!URxvt*secondaryScroll: True

URxvt.perl-ext-common: default,tabbed,matcher
URxvt.tabbed.tabbar-fg: 1
URxvt.tabbed.tabbar-bg: 0
URxvt.tabbed.tab-fg: 0
URxvt.tabbed.tab-bg: 1

URxvt*urlLauncher: iceweasel
URxvt.colorUL: #86a2be
rxvt*scrollBar_right:true
rxvt*transpscrollbar:true
rxvt*saveLines:: 32767

URxvt.depth: 32


